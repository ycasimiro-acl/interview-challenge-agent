<h1>🎯 Challenge Técnico — SRE Semi Senior</h1>

<div class="header-box">
  <table>
    <tr><td>Puesto</td><td>SRE Semi Senior</td></tr>
    <tr><td>Nivel</td><td>Semi Senior (Mid → Senior)</td></tr>
    <tr><td>Stack</td><td>AWS · Terraform · Docker · Kubernetes · Bash/Python · CI/CD · Grafana · Prometheus · OpenTelemetry</td></tr>
    <tr><td>Duración estimada</td><td>60 minutos</td></tr>
    <tr><td>Enfoque</td><td>Mixto (Teórico + Situacional + Código)</td></tr>
    <tr><td>Fecha de generación</td><td>2026-03-24</td></tr>
    <tr><td>Umbral de aprobación</td><td>≥ 14 / 21 puntos (67%)</td></tr>
  </table>
